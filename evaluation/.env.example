# Copy real object-store credentials here before launching sync_object_storage.py.
# Existing shell environment variables override values in this file.

AWS_ACCESS_KEY_ID=<access-key>
AWS_SECRET_ACCESS_KEY=<secret-key>

# Required for S3-compatible object storage. Leave empty for AWS S3.
S3_ENDPOINT_URL=https://chi.tacc.chameleoncloud.org:7480

# Optional, depending on your provider.
AWS_DEFAULT_REGION=us-east-1
